{
  "name": "desktop-app",
  "private": true,
  "version": "0.0.0",
  "description": "Presenter App - Desktop",
  "main": "dist/main/electron.js",
  "scripts": {
    "dev:react": "vite",
    "dev:electron:build": "tsup --watch",
    "dev:electron:start": "wait-on http://localhost:5173 && wait-on dist/main/electron.js && electron .",
    "dev": "concurrently -k -n REACT,TSUP,ELECTRON -c blue,yellow,green \"npm run dev:react\" \"npm run dev:electron:build\" \"npm run dev:electron:start\"",
    "build:react": "vite build",
    "build:electron": "tsup",
    "build": "npm run build:electron && npm run build:react",
    "dist": "npm run build && electron-builder",
    "build:bible": "ts-node --project scripts/tsconfig.json scripts/buildBibleDb.ts"
  },
  "build": {
    "appId": "com.presenterapp.desktop",
    "productName": "Petra Presenter App",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@reduxjs/toolkit": "^2.11.2",
    "cheerio": "^1.2.0",
    "express": "^5.2.1",
    "fs-extra": "^11.3.4",
    "ip": "^2.0.1",
    "konva": "^10.2.3",
    "lodash": "^4.17.23",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "nanoid": "^5.1.7",
    "node-fetch": "^3.3.2",
    "pdfjs-dist": "^3.11.174",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-konva": "^19.2.3",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.13.2",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "sql.js": "^1.14.1",
    "uuid": "^13.0.0",
    "word-extractor": "^1.0.4",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/fs-extra": "^11.0.4",
    "@types/ip": "^1.1.3",
    "@types/lodash": "^4.17.24",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.12.2",
    "@types/qrcode.react": "^1.0.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.0.4",
    "electron-builder": "^26.8.1",
    "electron-is-dev": "^3.0.1",
    "electron-reload": "^2.0.0-alpha.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tailwindcss": "^4.2.2",
    "tsup": "^8.5.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "wait-on": "^9.0.4"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs"
}
